.custom-navbar {
  position: fixed;
  top: 0; left: 0; width: 100%;
  background-color: #85A96F; 
  z-index: 999;
}

.navbar-content {
  height: 44px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 30rpx;
}

.nav-left, .nav-right {
  width: 60rpx; height: 100%;
  display: flex; align-items: center;
}

.back-icon {
  font-size: 40rpx; color: #333333; font-weight: bold;
}

.nav-title {
  flex: 1; text-align: center;
  font-size: 34rpx; font-weight: bold; color: #333333;
}

.nav-placeholder {
  width: 100%; background-color: transparent;
}

.gallery-container {
  min-height: 100vh;
  background-color: #EFE8D4; /* 强制米白底色 */
  display: flex;
  flex-direction: column;
}

.work-scroll {
  flex: 1;
  height: 0; 
  width: 100%;
}

.work-grid {
  display: flex;
  justify-content: space-between;
  padding: 180rpx 20rpx 60rpx; 
  box-sizing: border-box;
}

.work-column {
  width: 48.5%; /* 双列布局 */
  display: flex;
  flex-direction: column;
}

.work-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.work-image {
  width: 100%;
  display: block;
}

.work-info {
  padding: 20rpx;
}

.work-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
  margin-bottom: 12rpx;
  border-left: 6rpx solid #588FAC; /* 靛蓝装饰线 */
  padding-left: 12rpx;
}

.work-author {
  display: flex;
  align-items: center;
}

.author-tag {
  font-size: 18rpx;
  background-color: #C7CF61; /* 黄绿标签 */
  color: #FFFFFF;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
}

.author-id {
  font-size: 22rpx;
  color: #999999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  color: #999999;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}