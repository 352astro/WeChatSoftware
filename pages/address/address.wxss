/* pages/address/address.wxss */
.address-container {
  min-height: 100vh;
  background-color: #EFE8D4; /* 强制米白底色 */
  display: flex;
  flex-direction: column;
}

.address-scroll {
  flex: 1; /* 占据剩余空间 */
  height: calc(100vh - 180rpx); /* 减去导航栏高度 */
}

.address-list {
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

.address-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.phone {
  font-size: 28rpx;
  color: #666;
}

.tag {
  font-size: 20rpx;
  background-color: #588FAC; /* 靛蓝标签 */
  color: #FFFFFF;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 20rpx;
}

.address-detail {
  font-size: 26rpx;
  color: #333;
  line-height: 1.4;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
}

.default-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #999;
}

.operation-row {
  display: flex;
}

.op-btn {
  font-size: 26rpx;
  color: #588FAC;
  margin-left: 40rpx;
}

.text-green { color: #85A96F; }
.text-grey { color: #999; }

.bottom-bar {
position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 30rpx 40rpx calc(30rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.05);
  box-sizing: border-box;
}

.btn-add {
  background-color: #85A96F; /* 沉稳绿按钮 */
  color: #FFFFFF;
  border-radius: 50rpx;
  font-weight: bold;
}

.empty-wrapper {
  width: 100%;
  height: 100%; /* 继承 scroll-view 的高度 */
  display: flex;
  justify-content: center;
  align-items: center;
  padding-bottom: 200rpx; /* 视觉补偿，让位置稍微偏上一点更美观 */
  box-sizing: border-box;
}

.empty-box {
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 40rpx;
}