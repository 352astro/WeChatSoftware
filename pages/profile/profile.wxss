/* pages/profile/profile.wxss */
.profile-container {
  min-height: 100vh;
  background-color: #EFE8D4; /* 强制底色：宣纸米白 */
  display: flex;
  flex-direction: column;
}

/* --- 用户信息头部 --- */
.user-header {
  position: relative;
  background-color: #85A96F; /* 强制主色：沉稳绿，作为名片背景 */
  padding: 180rpx 40rpx 60rpx; /* 顶部留出导航栏高度 */
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 20rpx rgba(133, 169, 111, 0.2);
}

.user-info-box {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 2; /* 确保在装饰图形之上 */
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background-color: #EFE8D4; /* 米白底色衬托头像 */
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
  margin-right: 30rpx;
  border: 4rpx solid #FFFFFF;
}

.user-text {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.uid {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 装饰图形：增加文化韵味 */
.header-decoration {
  position: absolute;
  right: -40rpx;
  bottom: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.1);
  z-index: 1;
}

/* --- 功能菜单列表 --- */
.menu-list {
  background-color: #FFFFFF;
  margin: 40rpx 30rpx;
  border-radius: 20rpx;
  padding: 10rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 36rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
  width: 50rpx;
  text-align: center;
}

/* 利用文字颜色微调给不同菜单增加层级感，但在没有UI图前，主要靠Emoji */
.menu-name {
  flex: 1;
  font-size: 30rpx;
  color: #333333; /* 黑灰文字 */
  font-weight: 500;
}

.arrow {
  color: #CCCCCC;
  font-family: monospace; /* 简单的箭头 */
  font-size: 32rpx;
}

.divider {
  height: 16rpx;
  background-color: #FAFAFA;
  margin: 10rpx -30rpx;
}