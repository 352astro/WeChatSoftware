/* pages/pattern-library/pattern-library.wxss */
.page {
  min-height: 100vh;
  background: #EFE8D4;
  display: flex;
  flex-direction: column;
}

.top-bar {
  background: #85A96F;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  flex-shrink: 0;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  box-sizing: border-box;
}

.top-row {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}

.top-btn {
  width: 130rpx;
  font-size: 28rpx;
  color: #c8f7e8;
}

.top-placeholder {
  width: 130rpx;
}

.top-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #eafff8;
}

.pattern-scroll {
  flex: 1;
}

.section {
  padding: 30rpx 30rpx 0;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #588FAC;
  padding: 16rpx 0 20rpx;
  border-bottom: 2rpx solid #D4C9A8;
  margin-bottom: 20rpx;
}

.pattern-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-bottom: 30rpx;
}

.pattern-item {
  width: calc(33.33% - 14rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  active-opacity: 0.7;
}

.pattern-img {
  width: 100%;
  height: 180rpx;
  background: #f0ece0;
}

.pattern-name {
  font-size: 22rpx;
  color: #555;
  padding: 12rpx 8rpx;
  text-align: center;
}
