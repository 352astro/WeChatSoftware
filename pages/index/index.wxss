/**index.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}
.scrollarea {
  flex: 1;
  overflow-y: hidden;
}
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  background-color: #ffffff;
}

.logo-box {
  margin-top: 300rpx;
  text-align: center;
}

.logo {
  width: 200rpx;
  height: 200rpx;
}

.app-name {
  display: block;
  margin-top: 30rpx;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.footer {
  margin-bottom: 60rpx;
  font-size: 24rpx;
  color: #999;
}
