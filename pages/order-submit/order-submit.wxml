<view class="order-submit-container">
  
<view class="custom-navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-content">
      <view class="nav-left" bindtap="goBack">
        <text class="back-icon">←</text>
      </view>
      
      <view class="nav-title">确认订单</view> 
      
      <view class="nav-right"></view>
    </view>
  </view>

  <view class="nav-placeholder" style="height: {{statusBarHeight + 44}}px;"></view>

  <view class="address-section" bindtap="goToAddressSelect">
    <block wx:if="{{addressInfo.id}}">
      <view class="address-content">
         <view class="address-icon">📍</view>
         <view class="address-details">
           <view class="contact-info">
             <text class="name">{{addressInfo.name || addressInfo.consignee || addressInfo.receiverName}}</text>
             <text class="phone">{{addressInfo.phone || addressInfo.phoneNumber || addressInfo.receiverPhone}}</text>
           </view>
           <view class="detail-text">{{addressInfo.province || addressInfo.provinceName}}{{addressInfo.city || addressInfo.cityName}}{{addressInfo.district || addressInfo.districtName}}{{addressInfo.detail || addressInfo.detailAddress}}</view>
         </view>
         <view class="arrow-right">></view>
      </view>
    </block>
    <block wx:else>
       <view class="no-address">
         <view class="add-icon">+</view>
         <text>请选择收货地址</text>
         <view class="arrow-right">></view>
       </view>
    </block>
  </view>

  <view class="product-section">
    <view class="section-title">商品明细</view>
    
    <view class="product-item" wx:for="{{productList}}" wx:key="id">
      
      <view class="product-img">
        <image wx:if="{{item.imageUrl || item.image_url}}" src="{{item.imageUrl || item.image_url}}" mode="aspectFill" style="width:100%; height:100%; border-radius:12rpx;"></image>
        <text wx:else>📦</text>
      </view>

      <view class="product-info">
        <text class="title">{{item.name}}</text>
        <view class="price-row">
           <text class="price">¥ {{item.price}}</text>
           <text class="quantity">x {{item.count}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="additional-info-section">
     <view class="info-row">
        <text class="label">买家留言</text>
        <input class="remark-input" placeholder="选填，请先和商家协商一致" bindinput="onRemarkInput" />
     </view>
     <view class="info-row">
        <text class="label">商品总额</text>
        <text class="value text-green">¥ {{totalAmountStr}}</text>
     </view>
  </view>

  <view class="bottom-spacer"></view>

  <view class="submit-bar">
    <view class="total-display">
       <text>实付款：</text>
       <text class="final-price text-green">¥ {{totalAmountStr}}</text>
    </view>
    <button 
      class="btn-submit {{!addressInfo.id ? 'btn-disabled' : ''}}" 
      bindtap="submitOrder"
      disabled="{{!addressInfo.id || isSubmitting}}"
    >
      {{isSubmitting ? '提交中...' : '提交订单'}}
    </button>
  </view>

</view>