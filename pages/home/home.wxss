/* pages/home/home.wxss */
.home-page {
  min-height: 100vh;
  background-color: #FAFAFA; /* 极浅的暖灰色背景，更契合传统文化 */
  padding-bottom: 60rpx;
  overflow-x: hidden;
}

/* --- 1. 品牌愿景区 --- */
.hero-section {
  padding: 180rpx 50rpx 60rpx; /* 顶部留出导航栏空间 */
  background: linear-gradient(180deg, #FFFFFF 0%, #FAFAFA 100%);
}

.main-title {
  font-size: 72rpx;
  font-weight: 800;
  color: #333333;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.text-accent {
  color: #D35400; /* 提取一种偏古代朱砂红/蜜饯的重色调 */
}

.sub-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #666666;
  margin-bottom: 30rpx;
  letter-spacing: 2rpx;
}

.brand-desc {
  font-size: 26rpx;
  color: #888888;
  line-height: 1.6;
  text-align: justify; /* 两端对齐，让大段文字更整齐 */
}

/* --- 2. 核心功能卡片区 --- */
.feature-cards {
  display: flex;
  justify-content: space-between;
  padding: 0 40rpx;
  margin-top: -20rpx; /* 稍微向上悬浮一点 */
}

.feature-item {
  width: 30%;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.feature-icon {
  font-size: 56rpx; /* 在没有图片时，用放大字号的 Emoji 代替图标 */
  margin-bottom: 16rpx;
}

.feature-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}

/* --- 3. 匠心工艺科普区 --- */
.craft-section {
  padding: 60rpx 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 40rpx;
  text-align: center;
}

.craft-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx; /* 卡片之间的间距 */
}

.craft-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  border-left: 8rpx solid #D35400; /* 左侧加一条装饰线，增加设计感 */
}

.craft-step {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.craft-text {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}