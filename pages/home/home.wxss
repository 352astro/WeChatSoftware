/* pages/home/home.wxss */
.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f8f8f8; /* 浅灰色背景，更具质感 */
  padding: 0 40rpx;
  box-sizing: border-box;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center; /* 垂直居中 */
  align-items: center;    /* 水平居中 */
}

.welcome-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.card {
  width: 100%;
  background-color: #ffffff;
  padding: 60rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: center;
  align-items: center;
}

.card-text {
  color: #666;
  font-size: 32rpx;
}

.footer {
  padding-bottom: 60rpx;
  text-align: center;
  font-size: 24rpx;
  color: #ccc;
}

.card-btn {
  width: 100% !important; /* 覆盖按钮默认宽度 */
  background-color: #ffffff;
  padding: 60rpx 0 !important;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: center;
  align-items: center;
  border: none; /* 去掉默认边框 */
  font-weight: normal; /* 去掉默认粗体 */
}

/* 按钮点击时的视觉反馈 */
.btn-hover {
  background-color: #f0f0f0 !important;
  transform: scale(0.98); /* 轻微缩小，增加机械感 */
  transition: all 0.1s ease;
}

.card-text {
  color: #007AFF; /* 将文字改为蓝色，提示这是个可点击项 */
  font-size: 32rpx;
  font-weight: 500;
}