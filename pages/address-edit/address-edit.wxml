<view class="edit-container">
  
  <view class="custom-navbar" style="padding-top: {{statusBarHeight}}px;">
    <view class="navbar-content">
      <view class="nav-left" bindtap="goBack">
        <text class="back-icon">←</text>
      </view>
      <view class="nav-title">{{id ? '编辑收货地址' : '新增收货地址'}}</view>
      <view class="nav-right"></view>
    </view>
  </view>
  <view class="nav-placeholder" style="height: {{statusBarHeight + 44}}px;"></view>

  <view class="form-group">
    <view class="form-item">
      <text class="label">收货人</text>
      <input class="input-field" placeholder="请填写收货人姓名" placeholder-class="placeholder" value="{{consignee}}" bindinput="onInput" data-field="consignee" />
    </view>
    
    <view class="form-item">
      <text class="label">手机号码</text>
      <input class="input-field" type="number" maxlength="11" placeholder="请填写收货人手机号" placeholder-class="placeholder" value="{{phone}}" bindinput="onInput" data-field="phone" />
    </view>
    
    <view class="form-item align-top">
      <text class="label">详细地址</text>
      <textarea class="textarea-field" placeholder="街道、楼牌号等" placeholder-class="placeholder" value="{{detailAddress}}" bindinput="onInput" data-field="detailAddress"></textarea>
    </view>

    <view class="form-item">
      <text class="label">地址标签</text>
      <view class="tag-group">
        <view class="tag {{label === '家' ? 'tag-active' : ''}}" bindtap="chooseTag" data-tag="家">家</view>
        <view class="tag {{label === '公司' ? 'tag-active' : ''}}" bindtap="chooseTag" data-tag="公司">公司</view>
        <view class="tag {{label === '学校' ? 'tag-active' : ''}}" bindtap="chooseTag" data-tag="学校">学校</view>
      </view>
    </view>

    <view class="form-item border-none">
      <text class="label">设为默认收货地址</text>
      <switch checked="{{isDefault === 1}}" color="#85A96F" bindchange="onDefaultChange" />
    </view>
  </view>

  <view class="bottom-bar">
    <button class="btn-save" bindtap="saveAddress">保存地址</button>
  </view>

</view>