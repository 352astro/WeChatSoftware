<scroll-view class="product-list" scroll-y="true">
    
    <view class="product-card" wx:for="{{cartList}}" wx:key="id">
      
      <view class="product-img-box">
        <image wx:if="{{item.imageUrl && item.imageUrl.length > 5}}" src="{{item.imageUrl}}" mode="aspectFill" style="width:100%; height:100%; border-radius:12rpx;"></image>
        <text wx:else>{{item.imageUrl || '📦'}}</text>
      </view>
      
      <view class="product-info">
        <view class="product-title">{{item.name}}</view>
        <view class="product-desc">{{item.description}}</view>
        
        <view class="price-row">
          <text class="price">¥ {{item.price}}</text>
          
          <view class="stepper">
            <view class="btn-minus {{item.count === 0 ? 'btn-disabled' : ''}}" 
                  bindtap="changeCount" 
                  data-index="{{index}}" 
                  data-type="minus">-</view>
            <view class="count">{{item.count}}</view>
            <view class="btn-plus" 
                  bindtap="changeCount" 
                  data-index="{{index}}" 
                  data-type="plus">+</view>
          </view>
        </view>
      </view>
    </view>

    <view class="list-spacer"></view>
  </scroll-view>