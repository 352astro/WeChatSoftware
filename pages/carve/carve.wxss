/* pages/carve/carve.wxss */
.page {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #588FAC;
  color: #EFE8D4;
}

.top-bar {
  background: #85A96F;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  flex-shrink: 0;
}

.top-row {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}

.top-btn {
  width: 130rpx;
  font-size: 28rpx;
  color: #c8f7e8;
}

.top-placeholder {
  width: 130rpx;
}

.top-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #eafff8;
}

.save-btn {
  position: absolute;
  right: 24rpx;
  padding: 14rpx 32rpx;
  border-radius: 30rpx;
  background: #C7CF61;
  color: #ffffff;
  font-size: 28rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.25);
  z-index: 999;
}

.canvas-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 56rpx 24rpx 20rpx;
  box-sizing: border-box;
  position: relative;
}

.paint-canvas {
  border-radius: 50%;
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.2);
}

.bottom-bar {
  background: #85A96F;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  padding: 20rpx 24rpx 18rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}

.size-row {
  display: flex;
  align-items: center;
}

.size-label {
  font-size: 26rpx;
  color: #c8f7e8;
}

.size-slider {
  flex: 1;
  margin: 0 20rpx;
}

.size-value {
  width: 56rpx;
  text-align: right;
  font-size: 26rpx;
  color: #ffffff;
}

.tool-row {
  display: flex;
  margin-top: 18rpx;
  gap: 14rpx;
}

.tool-btn {
  flex: 1;
  height: 68rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #EFE8D4;
  background: #85A96F;
  border: 1px solid transparent;
}

.tool-btn-active {
  border-color: #C7CF61;
  background: #588FAC;
  color: #ffffff;
}

.tool-btn-danger {
  background: #7a3a3a;
  color: #ffecec;
}

.tool-btn-pattern {
  background: #588FAC;
  color: #eafff8;
  border-color: #C7CF61;
  font-size: 22rpx;
}

.tool-btn-pattern-active {
  background: #C7CF61;
  color: #ffffff;
  border-color: #C7CF61;
}

/* 花纹预览图（cover-image，覆盖在 canvas 上） */
.pattern-preview {
  position: absolute;
}

/* 花纹调整面板（替换底部工具栏，普通 view，位于 canvas 下方） */
.pattern-adjust-bar {
  background: #4a7a96;
}

.adjust-hint {
  font-size: 22rpx;
  color: #c8f7e8;
  margin-bottom: 8rpx;
}

/* 预览区：左侧预览窗口 + 右侧滑块并排 */
.adjust-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 4rpx;
}

/* 预览窗口：固定 80x80 正方形，居中显示预览图 */
.adjust-preview-wrap {
  width: 80px;
  height: 80px;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 12rpx;
  border: 1px solid rgba(199, 207, 97, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.adjust-preview-img {
  transition: width 0.1s, height 0.1s, transform 0.1s;
}

/* 滑块区占满剩余宽度 */
.adjust-sliders {
  flex: 1;
  min-width: 0;
}

.pattern-action-cancel {
  background: rgba(255,255,255,0.15);
  color: #EFE8D4;
  border: 1px solid rgba(255,255,255,0.2);
}

.pattern-action-confirm {
  background: #C7CF61;
  color: #ffffff;
}