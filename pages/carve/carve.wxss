/* pages/carve/carve.wxss */
.container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f0f0f0;
}

.paint-canvas {
  width: 100%;
  flex: 1;
  background-color: #ffffff;
}

.footer-bar {
  height: 150rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  background-color: #fff;
  border-top: 1rpx solid #eee;
}

.btn {
  font-size: 28rpx;
  background-color: #ff4d4f;
  color: white;
  margin-right: 20rpx;
}

.tips {
  font-size: 24rpx;
  color: #999;
}