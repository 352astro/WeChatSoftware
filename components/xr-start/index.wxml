<!-- components/xr-start/index.wxml -->
<xr-scene id="xr-scene" 
  bind:ready="handleReady" 
  bind:assets-progress="handleAssetsProgress" 
  bind:assets-loaded="handleAssetsLoaded">

  <xr-assets bind:progress="handleAssetsProgress"  bind:loaded="handleAssetsLoaded">
    <xr-asset-load type="gltf" asset-id="myModel" src="/assets/model.glb"/>
    <xr-asset-load type="texture" asset-id="customTexture" src="/assets/mask.png"/>
  </xr-assets>

  <xr-light type="ambient" color="1 1 1" intensity="1" />
  <xr-light type="directional" rotation="40 70 0" color="1 1 1" intensity="3" cast-shadow />
  <xr-mesh position="0 -1 0" scale="4 1 4" receive-shadow geometry="plane" uniforms="u_baseColorFactor:0.4 0.6 0.8 1" />
  <xr-gltf id="twa" node-id="modelNode" position="0 0 0" scale="1 1 1" model="myModel" cast-shadow />
  <xr-camera clear-color="0.4 0.8 0.6 1" position="0 1 10" target="modelNode" camera-orbit-control />

</xr-scene>